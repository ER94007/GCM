@model IEnumerable<GCM.Entity.HeadMasterEntity>;
@{
	ViewBag.Title = "Head";
	Layout = "~/Views/Shared/_Layout.cshtml";
	var msg = TempData["SaveStatus"] as string;
	int srNo = 1;

}

<script src="~/js/common.js"></script>
<script src="~/assets/dist/js/sweetalert.js"></script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<!-- Include Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<!-- Include Select2 JS -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>


<script src="~/lib/jquery/dist/jquery.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<div class="content-wrapper">
	<section class="content">
		<div class="container-fluid">
			<div class="row">
				<div class="col-12">
					<div class="card">
						<div class="card-header">
							<h3 class="card-title">Head List</h3>
						</div>
						<div class="card-body">
							<table id="HeadList" class="table table-bordered table-striped datatable">
								<thead>
									<tr>
										<th>Sr.</th>
										<th>Head Name</th>
										<th>Is Student Related</th>
										<th>Is Combined</th>
										<th>Update</th>
										<th>Delete</th>
									</tr>

								</thead>
								<tbody>
									@foreach (var item in Model)
									{
										<tr>
											<td>@srNo</td>

											<td>@item.HeadName</td>


											<td>@item.IsStudentRelated</td>
											<td>@item.IsCombined</td>
											<td>
												<a asp-controller="HeadMaster" asp-action="AddHeadMaster" asp-route-headmasterid="@item.HeadMasterId">
													<i class="fas fa-edit"></i>
												</a>
											</td>
											<td>
												<a onclick="deletehead(@item.HeadMasterId)">
													<i class="fas fa-trash-alt text-danger"></i>
												</a>
											</td>
										</tr>
										srNo++;
									}
								</tbody>
							</table>
						</div>
						<div class="text-center mt-3 mb-2">
							<a href="@Url.Action("AddHeadMaster", "HeadMaster")" class="btn btn-secondary">
								<i class="fas fa-list mr-1"></i>
								Go to Form
							</a>
							<button onclick="exportEntireTableToExcel('HeadList','FinancialBalance',[4,5])" class="btn btn-primary">
								Export to Excel
							</button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</div>

<script>
	function deletehead(HeadMasterId) {
		if (confirm("Are you sure you want to delete this subhead?")) {
			$.ajax({
				url: '/HeadMaster/Deletehead',  // Adjust the URL based on your controller
				type: 'POST',
				data: { HeadMasterId: HeadMasterId },
				success: function (response) {
					if (response.success) {
						alert(response.message);
						location.reload(); // Reload the page to update the list
					} else {
						alert("Error: " + response.message);
					}
				},
				error: function () {
					alert("An error occurred while deleting the student.");
				}
			});
		}
	}
	function exportTableToExcel(tableId, filename = 'ExportData', excludeColumns = []) {
		var table = document.getElementById(tableId);

		if (!table) {
			alert('Table not found!');
			return;
		}

		// Clone table to avoid modifying original
		var clonedTable = table.cloneNode(true);

		// Remove excluded columns (like action buttons)
		if (excludeColumns.length > 0) {
			var rows = clonedTable.querySelectorAll('tr');
			rows.forEach(function(row) {
				var cells = row.querySelectorAll('th, td');
				// Remove columns in reverse order to avoid index shifting
				for (var i = excludeColumns.length - 1; i >= 0; i--) {
					if (cells[excludeColumns[i]]) {
						cells[excludeColumns[i]].remove();
					}
				}
			});
		}

		// Convert to workbook and download
		var wb = XLSX.utils.table_to_book(clonedTable, {sheet: "Sheet1"});
		XLSX.writeFile(wb, filename + '_' + new Date().getTime() + '.xlsx');
	}
	$(document).ready(function () {
		  
		var msg = '@msg';
		if (msg != null && msg != '') {
			ShowDynamicSwalAlert("", msg);
		}
	});

</script>