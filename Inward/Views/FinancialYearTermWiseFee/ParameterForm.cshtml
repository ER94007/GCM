@model GCM.Entity.ParameterEntity;
<div class="content-wrapper">
	<section class="content">
		<div class="container-fluid">
			<div class="row">
				<div class="col-12">
					<div class="card">
						<div class="card-header">
							<h3 class="card-title">Parameter Form</h3>
						</div>
						<div class="card-body p-2">
							<div class="row">
								<div class="col-md-12">
									<div class="form-horizontal form-bordered">
										<div class="form-group row">
											<label class="control-label col-md-3">Finance Year:</label>
											<div class="col-md-9 control-form">
												<select class="form-control select2" id="reportSelect">
													<option class="bi-option" value="">---Select Report---</option>
@* 													<option class="bi-option" value="1">Student Details</option>
 *@													<option class="bi-option" value="2">Student Fee Reciept Report</option>
													<option class="bi-option" value="3">Student Fee Collection Report(FCR)</option>
@* 													<option class="bi-option" value="4">Verticle Ledger</option>
 *@													<option class="bi-option" value="5">FCR Exel</option>
												</select>
											</div>
										</div>
									</div>
								</div>
								<div class="col-md-4">
									<div id="yearSelection" style="margin-top: 10px; display: none;">
										<label for="yearSelect">Select Year:</label>
										<select class="form-control" id="yearSelect">
											<option value="">---Select Year---</option>
										</select>
									</div>
								</div>
								<div class="col-md-4">
									<div id="programSelection" style="margin-top: 10px; display: none;">
										<label for="programSelect">Select Program:</label>
										<select class="form-control" id="programSelect">
											<option value="">---Select Program---</option>
										</select>
									</div>
								</div>
								<div class="col-md-4">
									<div id="studentSelection" style="margin-top: 10px; display: none;">
										<label for="studentSelect">Select Student:</label>
										<select class="form-control" id="studentSelect">
											<option value="">---Select Student---</option>
										</select>
									</div>
								</div>
								<div class="col-md-4">
									<div id="termSelection" style="margin-top: 10px; display: none;">
										<label for="termSelect">Select Term:</label>
										<select class="form-control" id="termSelect">
											<option value="">---Select Term---</option>
										</select>
									</div>
								</div>

								<div class="col-md-4">
									<div id="fromdateSelection" style="margin-top: 10px; display: none;">
										<label for="fromdate">Select From Date:</label>
										<input type="date" class="form-control" id="fromdate" />
									</div>
								</div>
								<div class="col-md-4">
									<div id="todateSelection" style="margin-top: 10px; display: none;">
										<label for="todate">Select To Date:</label>
										<input type="date" class="form-control" id="todate" />
									</div>
								</div>
							</div>
							<div class="text-center" id="viewbtn">
								<button class="btn btn-primary" onclick="exportStudent()">View</button>
							</div>
							<div class="text-center" id="btnDetailReport" style="margin-top: 10px; display: none;">
								<button class="btn btn-primary" onclick="exportReport()">View</button>
							</div>

							<div class="text-center" id="btnFeecollectionReport" style="margin-top: 10px; display: none;">
								<button class="btn btn-primary" onclick="exportFeecollectionReport()">View</button>
							</div>
							<div class="text-center" id="btnFCREXL" style="margin-top: 10px; display: none;">
								<button class="btn btn-primary" onclick="exportfcrexl()">Get Excel</button>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</div>

<script>
	$(document).ready(function() {
		// Attach event handlers using jQuery
		$('#reportSelect').on('change', selectReport);
		$('#yearSelect').on('change', function() {
			BindStudent($(this).val());
		});
		$('#programSelect').on('change', function() {
			BindTerm($(this).val());
		});
		$('#termSelect').on('change', callBtn);
	});

	function selectReport(){
		var selectedopt = $('#reportSelect').val();

		// Hide all sections first
		$('#viewbtn').hide();
		$('#btnFeecollectionReport').hide();
		$('#btnDetailReport').hide();
		$('#btnFCREXL').hide();
		$('#yearSelection').hide();
		$('#programSelection').hide();
		$('#studentSelection').hide();
		$('#termSelection').hide();
		$('#fromdateSelection').hide();
		$('#todateSelection').hide();

		if(selectedopt == "1"){
				$('#yearSelection').show();
			$('#programSelection').show();
			BindYear();
			BindProgram();
			$('#viewbtn').show();
			
			
		}
		else if(selectedopt == "2"){
			$('#yearSelection').show();
			BindYear();
		}
		else if(selectedopt == "3"){
			$('#btnFeecollectionReport').show();
			$('#yearSelection').show();
			$('#programSelection').show();
			BindYear();
			BindProgram();
		}
		else if(selectedopt == "4"){
			$('#fromdateSelection').show();
			$('#todateSelection').show();
			$('#btnDetailReport').show();
		}
		else if(selectedopt == "5"){
				$('#yearSelection').show();
			$('#programSelection').show();
			BindYear();
			BindProgram();
			$('#btnFCREXL').show();
		}
		else{
			alert("Please select a valid option.");
		}
	}

	function BindYear(){
		var selectedopt = $('#reportSelect').val();
		$.ajax({
			url: '/Student/BindYear',
			type: 'GET',
			success: function (response) {
				if (response.success) {
					var yearDropdown = $('#yearSelect');
					yearDropdown.empty();
					yearDropdown.append('<option value="">---Select Year---</option>');

					$.each(response.data, function (index, year) {
						yearDropdown.append('<option value="' + year.value + '">' + year.text + '</option>');
					});

					if(selectedopt == "2"){
						$('#studentSelection').show();
						$('#programSelection').show();
						BindProgram();
					}
				} else {
					alert("Error: " + response.message);
				}
			},
			error: function () {
				alert("An error occurred while loading years.");
			}
		});
	}

	function BindProgram(){
		$.ajax({
			url: '/FinancialYearTermWiseFee/BindProgram',
			type: 'GET',
			success: function (response) {
				if (response) {
					var programDropdown = $('#programSelect');
					programDropdown.empty();
					programDropdown.append('<option value="0">---All---</option>');

					$.each(response.data, function (index, program) {
						programDropdown.append('<option value="' + program.value + '">' + program.text + '</option>');
					});
				} else {
					alert("Error: " + response.message);
				}
			},
			error: function () {
				alert("An error occurred while loading programs.");
			}
		});
	}

	function BindStudent(yearid){
		if(!yearid) return;

		$.ajax({
			url: '/Student/BindStudents',
			data: {yearid: yearid},
			type: 'GET',
			success: function (response) {
				if (response.success) {
					var studentDropdown = $('#studentSelect');
					studentDropdown.empty();
					studentDropdown.append('<option value="">---Select Student---</option>');

					$.each(response.data, function (index, student) {
						studentDropdown.append('<option value="' + student.value + '">' + student.text + '</option>');
					});
					$('#termSelection').show();
					BindTerm($('#programSelect').val());
				} else {
					alert("Error: " + response.message);
				}
			},
			error: function () {
				alert("An error occurred while loading students.");
			}
		});
	}

	function BindTerm(programid){
		if(!programid) {
			var termDropdown = $('#termSelect');
			termDropdown.empty();
			termDropdown.append('<option value="">---Select Term---</option>');
			return;
		}

		$.ajax({
			url: '/FinancialYearTermWiseFee/GetTermsByProgramId',
			data: {programid: programid},
			type: 'GET',
			success: function (response) {
				if (response) {
					var termDropdown = $('#termSelect');
					termDropdown.empty();
					termDropdown.append('<option value="0">---ALL---</option>');

					$.each(response, function (index, term) {
						termDropdown.append('<option value="' + term.value + '">' + term.text + '</option>');
					});

					$('#termSelection').show();
				} else {
					alert("Error: " + response.message);
				}
			},
			error: function () {
				alert("An error occurred while loading terms.");
			}
		});
	}

	function callBtn(){
		var yearid = $('#yearSelect').val();
		var studentid = $('#studentSelect').val();
		var termid = $('#termSelect').val();

		if(!yearid || !studentid || !termid) return;

		var url = '@Url.Action("ExportStudentFeeCollectionReport", "StudentFeeCollection")';
		url += '?studentid=' + studentid + '&yearid=' + yearid + '&termid=' + termid;

		var list = '<a href="' + url + '" class="btn btn-primary" target="_blank">View</a>';
		$('#viewbtn').html(list);
		$('#viewbtn').show();
	}

	function exportStudent(){
		const year = document.getElementById('yearSelect').value;
		const program = document.getElementById('programSelect').value;
		const term = document.getElementById('termSelect').value;

		if (!year || !program ) {
			alert("Please select year, program");
			return;
		}

		const url = `/Student/ExportStudentFeeDetailReport?YearId=${year}&ProgramId=${program}&TermId={term}`;
		var list = '<a href="/Student/ExportStudentFeeDetailReport?YearId=${year}&ProgramId=${program}&TermId={term}" class="btn btn-primary">View</a> ';
			$('#viewbtn').html(list);
		window.open(url, '_blank');
	}
	function exportReport() {
		const fromDate = document.getElementById('fromdate').value;
		const toDate = document.getElementById('todate').value;

		if (!fromDate || !toDate) {
			alert("Please select both From Date and To Date.");
			return;
		}

		const url = `/StudentFeeCollection/ExportFeeCollectionDetailReport?fromdate=${fromDate}&todate=${toDate}`;
		window.open(url, '_blank');
	}

	function exportFeecollectionReport() {
		const year = document.getElementById('yearSelect').value;
		const program = document.getElementById('programSelect').value;
		const term = document.getElementById('termSelect').value;

		if (!year || !program || !term) {
			alert("Please select year, program, and term.");
			return;
		}

		const url = `/Student/ExportStudentFeeDetailReport?YearId=${year}&ProgramId=${program}&TermId=${term}`;
		window.open(url, '_blank');
	}

	function exportfcrexl() {
		const year = document.getElementById('yearSelect').value;
		const program = document.getElementById('programSelect').value;
		const term = document.getElementById('termSelect').value;

		if (!year || !program || !term) {
			alert("Please select year, program, and term.");
			return;
		}
		const url = `/Student/DownloadFcrExcel?YearId=${year}&ProgramId=${program}&TermId=${term}`;
		window.open(url, '_blank');
	}
</script>