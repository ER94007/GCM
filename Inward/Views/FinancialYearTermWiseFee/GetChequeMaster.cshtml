@model IEnumerable<GCM.Entity.ChequeMaster>;
@{
	ViewBag.Title = "Expense";
	Layout = "~/Views/Shared/_Layout.cshtml";
	var msg = TempData["SaveStatus"] as string;
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.1.0/dist/css/adminlte.min.css">
<link href="~/assets/dist/css/sweetalert.css" />
<div class="content-wrapper">
	<section class="content">
		<div class="container-fluid">
			<div class="row">
				<div class="col-12">
					<div class="card">
						<div class="card-header">
							<h3 class="card-title">Cheque List</h3>
						</div>
						<div class="card-body">
							<table id="InwardList" class="table table-bordered table-striped">
								<thead>
									<tr>
										<th>Sr.</th>
										<th>Cheque No</th>
										<th>Edit</th>
									</tr>
								</thead>
								<tbody>
									@foreach (var item in Model)
									{
										<tr>
											<td>@item.ChequeMasterID</td>
											<td>@item.chequeno</td>
											<td><a asp-action="UpdateChequeById" asp-route-chequeid="@item.ChequeMasterID"><i class="fas fa-edit"></i></a></td>
										</tr>
									}
								</tbody>
							</table>
						</div>
						<div class="text-center mt-3 mb-2">
							<a href="@Url.Action("AddChequeNo", "FinancialYearTermWiseFee")" class="btn btn-secondary">
								<i class="fas fa-list mr-1"></i>
								Go to Form
							</a>
							<button onclick="exportEntireTableToExcel('InwardList','ChequeList',[])" class="btn btn-primary">
								Export to Excel
							</button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</div>

<script src="https://code.jquery.com/jquery-3.3.1.slim.min.js"></script>
<script src="https://code.jquery.com/jquery-3.3.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/popper.js@1.14.7/dist/umd/popper.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.min.js"></script>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script> <!-- Make sure jQuery is loaded first -->
<script src="path/to/select2.min.js"></script>

<!-- AdminLTE JS -->
<script src="https://cdn.jsdelivr.net/npm/admin-lte@3.1.0/dist/js/adminlte.min.js"></script>
<script src="~/js/common.js"></script>
<script src="~/assets/dist/js/sweetalert.js"></script>

<script type="text/javascript">
	function exportTableToExcel(tableId, filename = 'ExportData', excludeColumns = []) {
		var table = document.getElementById(tableId);

		if (!table) {
			alert('Table not found!');
			return;
		}

		// Clone table to avoid modifying original
		var clonedTable = table.cloneNode(true);

		// Remove excluded columns (like action buttons)
		if (excludeColumns.length > 0) {
			var rows = clonedTable.querySelectorAll('tr');
			rows.forEach(function(row) {
				var cells = row.querySelectorAll('th, td');
				// Remove columns in reverse order to avoid index shifting
				for (var i = excludeColumns.length - 1; i >= 0; i--) {
					if (cells[excludeColumns[i]]) {
						cells[excludeColumns[i]].remove();
					}
				}
			});
		}

		// Convert to workbook and download
		var wb = XLSX.utils.table_to_book(clonedTable, {sheet: "Sheet1"});
		XLSX.writeFile(wb, filename + '_' + new Date().getTime() + '.xlsx');
	}
	$(document).ready(function () {
		

	$('#InwardList').DataTable();
		var msg = '@msg';
		if (msg != null && msg != '') {
			ShowDynamicSwalAlert("", msg);
		}
	});
	
		
	
</script>